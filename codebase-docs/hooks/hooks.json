{
  "SessionStart": [
    {
      "type": "command",
      "command": "python3 \"CLAUDE_PLUGIN_ROOT/scripts/check-staleness.py\" --source-dir src --threshold-hours 24 2>/dev/null || python \"CLAUDE_PLUGIN_ROOT/scripts/check-staleness.py\" --source-dir src --threshold-hours 24 2>/dev/null || echo '{\"status\":\"check_failed\"}'",
      "timeout": 10
    }
  ],
  "Stop": [
    {
      "type": "command",
      "command": "python3 \"CLAUDE_PLUGIN_ROOT/scripts/detect-changes.py\" --source-dir src/openturtle_os 2>/dev/null || python \"CLAUDE_PLUGIN_ROOT/scripts/detect-changes.py\" --source-dir src/openturtle_os 2>/dev/null || echo '{\"total_changes\":0}'",
      "timeout": 10
    }
  ]
}
